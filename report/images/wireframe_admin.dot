digraph G {
  graph [rankdir=TB, bgcolor="white", nodesep=0.35, ranksep=0.45, fontname="DejaVu Sans"];
  node [shape=box, fontname="DejaVu Sans", fontsize=11, style="rounded,filled", fillcolor="#f8f8f8"];
  edge [style=invis];

  header [label="Шапка: Панель управления | Администратор: Смирнова А.А. | [Выйти]", width=7.5];
  col1 [label="Боковое меню\n[Управление врачами]\n[Управление услугами]\n[Расписание клиники]\n[База пациентов]\n[Управление записями]", width=2.4];
  col2 [label="Раздел: Управление расписанием врачей\nФильтры: [Выбрать дату: 28.05.2026] | [Выбрать врача: Иванов И.И. (Терапевт)]\n\nТаблица слотов расписания:\n09:00 - Занят (Пациент: Амплеенков Д.О.) [Отменить запись]\n09:30 - Занят (Пациент: Сидоров С.С.) [Отменить запись]\n10:00 - Свободен [Изменить] [Удалить]\n10:30 - Свободен [Изменить] [Удалить]\n\n[Кнопка: Добавить новые слоты в расписание]", width=4.8];
  footer [label="Подвал: Административный интерфейс управления ресурсами клиники. Сессия активна.", width=7.5];

  header -> col1;
  header -> col2;
  col1 -> footer;
  col2 -> footer;

  {rank=same; col1; col2;}
}
